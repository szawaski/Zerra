<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net48</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <LangVersion>14.0</LangVersion>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
        <PackageLicenseFile>LICENSE</PackageLicenseFile>
    </PropertyGroup>

    <PropertyGroup>
        <Version>6.0.0</Version>
        <Authors>Steven Zawaski</Authors>
        <Company>KaKush LLC</Company>
        <Copyright>KaKush LLC</Copyright>
        <Product>Zerra Framework</Product>
        <RepositoryUrl>https://github.com/szawaski/Zerra</RepositoryUrl>
        <PackageTags>Zerra, T4</PackageTags>
        <Description>Tools for T4 files to use to generate code and client side libraries for CQRS.</Description>
    </PropertyGroup>

    <ItemGroup>
        <None Include="..\..\LICENSE" Link="LICENSE">
            <PackagePath>\</PackagePath>
            <Pack>True</Pack>
        </None>
    </ItemGroup>

    <ItemGroup>
        <Service Include="{508349b6-6b84-4df5-91f0-309beebad82d}" />
    </ItemGroup>

    <!-- Copy build output to Front End Scripts Binaries folder -->
    <Target Name="CopyToFrontEndScripts" AfterTargets="Build">
        <PropertyGroup>
            <FrontEndBinariesPath>$(SolutionDir)Front End Scripts\Binaries\</FrontEndBinariesPath>
        </PropertyGroup>
        <ItemGroup>
            <BinariesToCopy Include="$(OutputPath)Zerra.T4.dll" />
            <BinariesToCopy Include="$(OutputPath)Zerra.T4.pdb" />
            <BinariesToCopy Include="$(OutputPath)Zerra.T4.xml" />
        </ItemGroup>
        <Message Text="Copying Zerra.T4 binaries to Front End Scripts folder..." Importance="high" />
        <Copy SourceFiles="@(BinariesToCopy)" DestinationFolder="$(FrontEndBinariesPath)" SkipUnchangedFiles="true" />
        <Message Text="Successfully copied binaries to $(FrontEndBinariesPath)" Importance="high" />
    </Target>

</Project>
